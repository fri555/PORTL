# ========== AI工作门户 后端配置 ==========

# 服务端口
PORT=8090
HOST=0.0.0.0

# 数据库 (默认 SQLite，生产环境改为 PostgreSQL)
DATABASE_URL=sqlite:///./data/tianma_ai.db

# JWT
SECRET_KEY=change-me-in-production-use-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# AI 模型配置
DEFAULT_AI_PROVIDER=deepseek
DEFAULT_AI_MODEL=deepseek-v4-flash
AI_API_KEY=sk-c50f37bbb57747a9b92b25915c9d8d97
AI_API_BASE=https://api.deepseek.com

# 钉钉集成
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_CORP_ID=

# 文件存储
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# CORS
CORS_ORIGINS=http://localhost:5176,http://localhost:5173
